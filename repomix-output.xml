  --secondary: oklch(0.26 0.035 280);
  --secondary-foreground: oklch(0.98 0.005 280);

  --muted: oklch(0.24 0.03 280);
  --muted-foreground: oklch(0.68 0.03 280);

  --accent: oklch(0.30 0.06 290);
  --accent-foreground: oklch(0.98 0.005 280);

  --destructive: oklch(0.62 0.24 22);
  --destructive-foreground: oklch(0.99 0 0);

  --border: oklch(0.30 0.03 280 / 60%);
  --input: oklch(0.26 0.03 280);
  --ring: oklch(0.68 0.22 295);

  --brand: oklch(0.68 0.22 295);
  --brand-glow: oklch(0.78 0.18 320);
  --accent-cyan: oklch(0.78 0.15 210);
  --success: oklch(0.72 0.18 155);

  --gradient-brand: linear-gradient(135deg, oklch(0.68 0.22 295), oklch(0.72 0.20 220));
  --gradient-glow: radial-gradient(circle at 50% 0%, oklch(0.68 0.22 295 / 0.35), transparent 60%);
  --gradient-mesh: radial-gradient(at 20% 10%, oklch(0.55 0.25 295 / 0.25) 0px, transparent 50%),
                   radial-gradient(at 80% 20%, oklch(0.60 0.22 220 / 0.20) 0px, transparent 50%),
                   radial-gradient(at 40% 90%, oklch(0.65 0.20 320 / 0.18) 0px, transparent 50%);
  --shadow-glow: 0 0 40px oklch(0.68 0.22 295 / 0.35);
  --shadow-card: 0 8px 32px oklch(0 0 0 / 0.4);

  --sidebar: oklch(0.14 0.02 280);
  --sidebar-foreground: oklch(0.92 0.01 280);
  --sidebar-primary: oklch(0.68 0.22 295);
  --sidebar-primary-foreground: oklch(0.99 0 0);
  --sidebar-accent: oklch(0.22 0.03 280);
  --sidebar-accent-foreground: oklch(0.98 0.005 280);
  --sidebar-border: oklch(0.25 0.03 280 / 50%);
  --sidebar-ring: oklch(0.68 0.22 295);
}

.light {
  --background: oklch(0.99 0.003 280);
  --foreground: oklch(0.18 0.02 280);
  --card: oklch(1 0 0);
  --card-foreground: oklch(0.18 0.02 280);
  --popover: oklch(1 0 0);
  --popover-foreground: oklch(0.18 0.02 280);
  --primary: oklch(0.55 0.22 295);
  --primary-foreground: oklch(0.99 0 0);
  --secondary: oklch(0.96 0.01 280);
  --secondary-foreground: oklch(0.20 0.02 280);
  --muted: oklch(0.96 0.01 280);
  --muted-foreground: oklch(0.50 0.03 280);
  --accent: oklch(0.94 0.03 295);
  --accent-foreground: oklch(0.20 0.02 280);
  --border: oklch(0.90 0.01 280);
  --input: oklch(0.93 0.01 280);
  --ring: oklch(0.55 0.22 295);
  --sidebar: oklch(0.98 0.005 280);
  --sidebar-foreground: oklch(0.20 0.02 280);
  --sidebar-accent: oklch(0.94 0.02 295);
  --sidebar-accent-foreground: oklch(0.20 0.02 280);
  --sidebar-border: oklch(0.90 0.01 280);
}

@layer base {
  * { border-color: var(--color-border); }
  html { font-family: var(--font-sans); }
  body {
    background-color: var(--color-background);
    color: var(--color-foreground);
    font-feature-settings: "cv02", "cv03", "cv04", "cv11";
    -webkit-font-smoothing: antialiased;
  }
  h1, h2, h3, h4, h5 { font-family: var(--font-display); letter-spacing: -0.02em; }
}

@utility text-gradient {
  background: var(--gradient-brand);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

@utility bg-gradient-brand {
  background-image: var(--gradient-brand);
}

@utility bg-mesh {
  background-image: var(--gradient-mesh);
}

@utility glass {
  background-color: oklch(1 0 0 / 0.04);
  backdrop-filter: blur(20px) saturate(140%);
  border: 1px solid oklch(1 0 0 / 0.08);
}

@utility shadow-glow {
  box-shadow: var(--shadow-glow);
}

@utility shadow-card {
  box-shadow: var(--shadow-card);
}
